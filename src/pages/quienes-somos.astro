---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Quiénes Somos - Tecnioca" lang="es">
  <Header slot="header" lang="es" />
  
  <main class="min-h-screen">
    <div class="bg-gradient-to-r from-blue-600 to-blue-700 text-white py-20">
      <div class="container mx-auto px-4 text-center">
        <h1 class="text-5xl font-bold font-display mb-4">Quiénes Somos</h1>
        <p class="text-xl text-blue-100">Más de 20 años de excelencia en inspección industrial</p>
      </div>
    </div>

    <section class="py-20 bg-white dark:bg-slate-800">
      <div class="container mx-auto px-4 max-w-4xl">
        <h2 class="text-4xl font-bold font-display mb-8 text-slate-900 dark:text-white">Nuestra Historia</h2>
        <p class="text-lg text-slate-700 dark:text-slate-300 mb-6 leading-relaxed">
          Tecnioca es una empresa especializada en inspección y control industrial con más de 20 años de experiencia en el sector.
        </p>
        <p class="text-lg text-slate-700 dark:text-slate-300 mb-6 leading-relaxed">
          Estamos comprometidos con la excelencia, la seguridad y el cumplimiento normativo en todos nuestros servicios.
        </p>
        <p class="text-lg text-slate-700 dark:text-slate-300 leading-relaxed">
          Nuestro equipo de profesionales altamente cualificados trabaja para garantizar que cada inspección se realice conforme a las más altas estándares de calidad.
        </p>
      </div>
    </section>
  </main>
  
  <Footer slot="footer" lang="es" />
</BaseLayout>
