---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout title="Accreditations - Tecnioca" lang="en">
  <Header slot="header" lang="en" />
  
  <main class="min-h-screen">
    <div class="bg-gradient-to-r from-blue-600 to-blue-700 text-white py-20">
      <div class="container mx-auto px-4 text-center">
        <h1 class="text-5xl font-bold font-display mb-4">Accreditations</h1>
        <p class="text-xl text-blue-100">Quality certifications and accreditations</p>
      </div>
    </div>

    <section class="py-20 bg-white dark:bg-slate-800">
      <div class="container mx-auto px-4 max-w-4xl">
        <p class="text-lg text-slate-700 dark:text-slate-300 leading-relaxed">
          Tecnioca possesses all necessary accreditations to perform industrial inspections in accordance with current regulations.
        </p>
        <p class="text-lg text-slate-700 dark:text-slate-300 leading-relaxed mt-6">
          Our certifications guarantee the quality and reliability of our services.
        </p>
      </div>
    </section>
  </main>
  
  <Footer slot="footer" lang="en" />
</BaseLayout>
