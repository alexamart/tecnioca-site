---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout title="EICI Services - Tecnioca" lang="en">
  <Header slot="header" lang="en" />
  
  <main class="min-h-screen">
    <div class="bg-gradient-to-r from-blue-600 to-blue-700 text-white py-20">
      <div class="container mx-auto px-4 text-center">
        <h1 class="text-5xl font-bold font-display mb-4">EICI Services</h1>
        <p class="text-xl text-blue-100">Certified Industrial Inspection Entity</p>
      </div>
    </div>

    <section class="py-20 bg-white dark:bg-slate-800">
      <div class="container mx-auto px-4 max-w-4xl">
        <h2 class="text-3xl font-bold font-display mb-6 text-slate-900 dark:text-white">EICI Inspection Services</h2>
        <div class="space-y-6">
          <div>
            <h3 class="text-xl font-bold font-display text-slate-900 dark:text-white mb-2">Low Voltage (Non-Industrial)</h3>
            <p class="text-slate-700 dark:text-slate-300">Inspections according to applicable regulations in low voltage installations for non-industrial use.</p>
          </div>
          <div>
            <h3 class="text-xl font-bold font-display text-slate-900 dark:text-white mb-2">Pressure Equipment</h3>
            <p class="text-slate-700 dark:text-slate-300">Certified inspections of pressure equipment in accordance with applicable regulations.</p>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer slot="footer" lang="en" />
</BaseLayout>
