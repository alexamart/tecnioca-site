---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout title="Contact - Tecnioca" lang="en">
  <Header slot="header" lang="en" />
  
  <main class="min-h-screen">
    <div class="bg-gradient-to-r from-blue-600 to-blue-700 text-white py-20">
      <div class="container mx-auto px-4 text-center">
        <h1 class="text-5xl font-bold font-display mb-4">Contact Us</h1>
        <p class="text-xl text-blue-100">Get in touch with us</p>
      </div>
    </div>

    <section class="py-20 bg-white dark:bg-slate-800">
      <div class="container mx-auto px-4 max-w-4xl">
        <div class="grid md:grid-cols-2 gap-12">
          <div>
            <h3 class="text-2xl font-bold font-display mb-4 text-slate-900 dark:text-white">Contact Information</h3>
            <div class="space-y-4 text-slate-700 dark:text-slate-300">
              <p><strong>Phone:</strong> (+34) 919 395 212</p>
              <p><strong>Email:</strong> contacto@tecnioca.es</p>
              <p><strong>Hours:</strong> Monday to Friday, 9:00 - 18:00</p>
            </div>
          </div>
          <div>
            <h3 class="text-2xl font-bold font-display mb-4 text-slate-900 dark:text-white">Request Inspection</h3>
            <form class="space-y-4">
              <input type="text" placeholder="Your name" class="w-full px-4 py-2 border border-slate-300 rounded-lg dark:bg-slate-700 dark:text-white" />
              <input type="email" placeholder="Your email" class="w-full px-4 py-2 border border-slate-300 rounded-lg dark:bg-slate-700 dark:text-white" />
              <textarea placeholder="Your message" rows="4" class="w-full px-4 py-2 border border-slate-300 rounded-lg dark:bg-slate-700 dark:text-white"></textarea>
              <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-lg font-semibold transition-colors">
                Send
              </button>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer slot="footer" lang="en" />
</BaseLayout>
