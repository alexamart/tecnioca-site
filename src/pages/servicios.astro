---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Servicios - Tecnioca" lang="es">
  <Header slot="header" lang="es" />
  
  <main class="min-h-screen">
    <div class="bg-gradient-to-r from-blue-600 to-blue-700 text-white py-20">
      <div class="container mx-auto px-4 text-center">
        <h1 class="text-5xl font-bold font-display mb-4">Nuestros Servicios</h1>
        <p class="text-xl text-blue-100">Inspección y control industrial de calidad</p>
      </div>
    </div>

    <section class="py-20 bg-white dark:bg-slate-800">
      <div class="container mx-auto px-4 max-w-4xl">
        <div class="space-y-12">
          <div>
            <h2 class="text-3xl font-bold font-display mb-4 text-slate-900 dark:text-white">Servicios OCA</h2>
            <p class="text-lg text-slate-700 dark:text-slate-300 leading-relaxed">
              Como Organismo de Control Autorizado, ofrecemos inspecciones en baja tensión, alta tensión, equipos a presión y gases combustibles.
            </p>
          </div>
          <div>
            <h2 class="text-3xl font-bold font-display mb-4 text-slate-900 dark:text-white">Servicios EICI</h2>
            <p class="text-lg text-slate-700 dark:text-slate-300 leading-relaxed">
              Como Entidad de Inspección Industrial Certificada, realizamos inspecciones especializadas conforme a la normativa aplicable.
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer slot="footer" lang="es" />
</BaseLayout>
