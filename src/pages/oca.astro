---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="OCA - Tecnioca" lang="es">
  <Header slot="header" lang="es" />
  
  <main class="min-h-screen">
    <div class="bg-gradient-to-r from-blue-600 to-blue-700 text-white py-20">
      <div class="container mx-auto px-4 text-center">
        <h1 class="text-5xl font-bold font-display mb-4">Servicios OCA</h1>
        <p class="text-xl text-blue-100">Organismo de Control Autorizado</p>
      </div>
    </div>

    <section class="py-20 bg-white dark:bg-slate-800">
      <div class="container mx-auto px-4 max-w-4xl">
        <h2 class="text-3xl font-bold font-display mb-6 text-slate-900 dark:text-white">Servicios de Inspección OCA</h2>
        <div class="space-y-6">
          <div>
            <h3 class="text-xl font-bold font-display text-slate-900 dark:text-white mb-2">Baja Tensión</h3>
            <p class="text-slate-700 dark:text-slate-300">Inspecciones iniciales y periódicas en instalaciones eléctricas de baja tensión.</p>
          </div>
          <div>
            <h3 class="text-xl font-bold font-display text-slate-900 dark:text-white mb-2">Alta Tensión</h3>
            <p class="text-slate-700 dark:text-slate-300">Centros de Transformación de hasta 30kV y Líneas Eléctricas de Alta Tensión.</p>
          </div>
          <div>
            <h3 class="text-xl font-bold font-display text-slate-900 dark:text-white mb-2">Equipos a Presión</h3>
            <p class="text-slate-700 dark:text-slate-300">Inspecciones en el lugar de emplazamiento y periódicas de equipos a presión.</p>
          </div>
          <div>
            <h3 class="text-xl font-bold font-display text-slate-900 dark:text-white mb-2">Gases Combustibles</h3>
            <p class="text-slate-700 dark:text-slate-300">Inspecciones iniciales y periódicas según la normativa aplicable.</p>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer slot="footer" lang="es" />
</BaseLayout>
